let i   = 1;
let sum = 0;

while (i <= 10) {
    sum = sum + i;
    i   = i + 1;
}

print sum;

let n = 0;
while (n < 6) {
    if (n == 0) {
        print 100;
    } else {
        if (n == 2) {
            print 200;
        } else {
            if (n == 4) {
                print 400;
            } else {
                print n;
            }
        }
    }
    n = n + 1;
}
